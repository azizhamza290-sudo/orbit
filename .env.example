# ─────────────────────────────────────────────
# Orbit — Environment Variables
# Copy this file to `.env` and fill in values.
# ─────────────────────────────────────────────

# Database (Vercel Postgres — copy from your Vercel Storage dashboard)
POSTGRES_PRISMA_URL="postgres://user:password@host:5432/db?pgbouncer=true&connection_limit=1"
POSTGRES_URL_NON_POOLING="postgres://user:password@host:5432/db"

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OAuth providers (optional — credentials auth works without them)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Email (Resend — https://resend.com, free tier). If unset, emails are logged to the server console in development.
RESEND_API_KEY=""
EMAIL_FROM="Orbit <noreply@yourdomain.com>"

# Pusher (https://pusher.com — free tier)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# Vercel Blob (from your Vercel Storage dashboard)
BLOB_READ_WRITE_TOKEN=""
